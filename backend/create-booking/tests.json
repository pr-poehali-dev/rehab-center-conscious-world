    },
    {
      "name": "Ошибка без имени",
      "method": "POST",
      "path": "/",
      "body": { "phone": "+79001234567" },
      "expectedStatus": 400,
      "expectedBody": { "error": "Имя и телефон обязательны" },
      "bodyMatcher": "partial"
    }
  ]
